# Firebase / Firestore — enables persistent sessions + RSVPs.
# Leave these blank to use the in-memory store (dev only; resets on restart).
# These values are NOT secret — the Firebase web config ships to clients by design;
# access is controlled by Firestore security rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# optional — defaults to <project-id>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
